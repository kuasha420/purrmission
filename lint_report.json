lls[0].arguments[0].content, /APPROVED/);\n    });\n\n    it('should handle failure from service', async () => {\n        const mockReply = mock.fn();\n        const interaction = {\n            options: {\n                getString: mock.fn(() => 'req-123'),\n            },\n            user: { id: 'guardian-1' },\n            reply: mockReply,\n        } as any;\n\n        const services = {\n            approval: {\n                recordDecision: mock.fn(async () => ({ success: false, error: 'Not found' })),\n            },\n        } as any;\n\n        await execute(interaction, services);\n\n        assert.strictEqual(mockReply.mock.calls.length, 1);\n        assert.match(mockReply.mock.calls[0].arguments[0].content, /Failed to approve request/);\n    });\n\n    it('should handle exceptions from service', async () => {\n        const mockReply = mock.fn();\n        const interaction = {\n            options: {\n                getString: mock.fn(() => 'req-123'),\n            },\n            user: { id: 'guardian-1' },\n            reply: mockReply,\n            replied: false,\n            deferred: false,\n        } as any;\n\n        const services = {\n            approval: {\n                recordDecision: mock.fn(async () => { throw new Error('Database error'); }),\n            },\n        } as any;\n\n        await execute(interaction, services);\n\n        assert.strictEqual(mockReply.mock.calls.length, 1);\n        assert.match(mockReply.mock.calls[0].arguments[0].content, /An unexpected error occurred/);\n    });\n});\n","usedDeprecatedRules":[]},{"filePath":"/Users/kuasha/Dev/purrmission/apps/purrmission-bot/src/discord/commands/approve.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/kuasha/Dev/purrmission/apps/purrmission-bot/src/discord/commands/auth.test.ts","messages":[{"ruleId":"@typescript-eslint/no-explici